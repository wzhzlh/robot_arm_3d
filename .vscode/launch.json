{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug with OpenOCD + GDB",
            "type": "cppdbg",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "build/Debug/robot_arm_3d.elf",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/arm-none-eabi-gdb",
            "miDebuggerServerAddress": "localhost:3333",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing"
                },
                {
                    "description": "Halt target",
                    "text": "monitor reset halt"
                }
            ],
            "preLaunchTask": "OpenOCD Server",
            "postDebugTask": "Terminate OpenOCD"
        },
        {
            "name": "Debug with Cortex-Debug (推荐)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "build/Debug/robot_arm_3d.elf",
            "servertype": "openocd",
            "configFiles": [
                "interface/jlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "interface": "swd",
            "device": "STM32F407VG",
            "runToMain": true,
            "preLaunchTask": "Build Debug",
            "svdFile": "debug/STM32F407.svd",
            "showDevDebugOutput": false
        }
    ]
}
