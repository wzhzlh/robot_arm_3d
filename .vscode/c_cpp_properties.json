{
    "configurations": [
        {
            "name": "STM32F407",
            "compilerPath": "/usr/bin/arm-none-eabi-gcc",
            "includePath": [
                "${workspaceFolder}/Core/**",
                "${workspaceFolder}/Drivers/**",
                "${workspaceFolder}/Middlewares/**",
                "${workspaceFolder}/My_lib/**",
                "${workspaceFolder}/My_task/**",
                "${workspaceFolder}/MDK-ARM/**",
                "${workspaceFolder}/cmake/stm32cubemx/**"
