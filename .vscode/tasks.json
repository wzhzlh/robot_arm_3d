{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Release",
            "type": "shell",
            "command": "cmake --build --preset Release",
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "cmake --build --preset Debug",
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "rm -rf build",
            "problemMatcher": []
        },
        {
            "label": "Flash with OpenOCD",
            "type": "shell",
            "command": "openocd -f openocd.cfg -c \"program build/Release/robot_arm_3d.elf verify reset exit\"",
            "problemMatcher": [],
            "dependsOn": ["Build Release"],
            "group": "none"
        },
        {
            "label": "Flash with OpenOCD (Debug)",
            "type": "shell",
            "command": "openocd -f openocd.cfg -c \"program build/Debug/robot_arm_3d.elf verify reset exit\"",
            "problemMatcher": [],
            "dependsOn": ["Build Debug"],
            "group": "none"
        },
        {
            "label": "OpenOCD Server",
            "type": "shell",
            "command": "openocd -f openocd.cfg",
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "Terminate OpenOCD",
            "type": "shell",
            "command": "pkill openocd || true",
            "problemMatcher": [],
            "dependsOn": []
        },
        {
            "label": "Open Ozone",
            "type": "shell",
            "command": "ozone -j debug/robot_arm_3d.jdebug",
            "problemMatcher": [],
            "group": "none"
        },
        {
            "label": "Open Ozone with OpenOCD backend",
            "type": "shell",
            "command": "ozone -j debug/robot_arm_3d.jdebug",
            "problemMatcher": [],
            "dependsOn": ["OpenOCD Server"]
        },
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake --preset Debug",
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "label": "CMake Configure (Release)",
            "type": "shell",
            "command": "cmake --preset Release",
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "label": "Build All (Release + Debug)",
            "type": "shell",
            "command": "cmake --build --preset Release && cmake --build --preset Debug",
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "label": "Flash & Debug (一键烧录+调试)",
            "type": "shell",
            "command": "openocd -f openocd.cfg -c \"program build/Debug/robot_arm_3d.elf verify reset exit\" && echo '=== 烧录完成，开始 GDB 调试 ===' && arm-none-eabi-gdb build/Debug/robot_arm_3d.elf -ex 'target remote localhost:3333' -ex 'monitor reset halt' -ex 'load'",
            "problemMatcher": [],
            "dependsOn": ["Build Debug"]
        }
    ]
}
